{
  "uid": "unified-observability",
  "title": "SkillBridge — Unified Observability",
  "description": "Metrics, Logs, and Traces in one view. Click metric spikes to drill down into Loki logs, then click trace IDs to open in Tempo.",
  "tags": ["unified", "correlation", "traces", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "production,staging",
        "options": [],
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Golden Signals — Entry Point for Investigation",
      "description": "Click any panel to navigate to correlated Loki logs for the selected time window.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "description": "Spike here? Click 'Explore in Loki' to see correlated error logs, then follow trace IDs to Tempo.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\", job=~\"$service\", environment=~\"$environment\"}[5m]))",
          "legendFormat": "Error rate (5xx/s)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\", environment=~\"$environment\"}[5m]))",
          "legendFormat": "Total request rate (/s)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error rate (5xx/s)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "links": [
        {
          "title": "Explore errors in Loki",
          "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"expr\":\"{job=~\\\"$service\\\", environment=~\\\"$environment\\\"} | json | level=~\\\"error|warn\\\"\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "description": "Latency spike? Drill down to Loki slow-request logs, then find the causing trace in Tempo.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\", environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p99 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\", environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p95 latency",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$service\", environment=~\"$environment\"}[5m])) by (le))",
          "legendFormat": "p50 latency",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red",    "value": 0.5 }
            ]
          }
        }
      },
      "links": [
        {
          "title": "Explore slow requests in Loki",
          "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"expr\":\"{job=~\\\"$service\\\", environment=~\\\"$environment\\\"} | json | level=\\\"error\\\"\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Volume",
      "description": "Traffic — requests per second by service.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\", environment=~\"$environment\"}[5m])) by (job, environment)",
          "legendFormat": "{{ job }} {{ environment }} RPS",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 5,
      "title": "Error Ratio",
      "description": "Percentage of requests returning 5xx.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$service\", status=~\"5..\", environment=~\"$environment\"}[5m])) by (job, environment) / sum(rate(http_requests_total{job=~\"$service\", environment=~\"$environment\"}[5m])) by (job, environment) * 100",
          "legendFormat": "{{ job }} {{ environment }} error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 6,
      "title": "SLO Burn Rate",
      "description": "Real-time burn rate. Threshold lines at 5x (slow burn) and 14.4x (fast burn).",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "job:http_request_errors:ratio1h{job=\"skillbridge-api\"} / 0.01",
          "legendFormat": "Burn Rate (1h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Correlated Logs — Step 2 of Drill-Down",
      "description": "Loki logs filtered to the selected service and time window. Look for traceID= fields — click them to open in Tempo.",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Application Logs",
      "description": "Logs from the selected service. Error and warning lines are highlighted. Click any traceID= value to jump to Tempo.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=~\"$service\", environment=~\"$environment\"} |= \"\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 12,
      "title": "Error & Warning Logs",
      "description": "Structured JSON logs filtered to warn and error levels from the selected service.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=~\"$service\", environment=~\"$environment\"} | json | level=~\"error|warn\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
