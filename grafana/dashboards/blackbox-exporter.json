{
  "uid": "blackbox-exporter",
  "title": "SkillBridge — Uptime & SSL",
  "description": "HTTP uptime probes and SSL certificate expiry for backend and frontend endpoints.",
  "tags": ["skillbridge", "blackbox", "uptime", "ssl"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "production,staging",
        "options": [],
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "query": "backend,frontend",
        "options": [],
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Uptime",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Probe Success (24h)",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-http\", environment=~\"$environment\", service=~\"$service\"}[24h]) * 100",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Probe Success Over Time",
      "gridPos": { "x": 8, "y": 1, "w": 16, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-http\", environment=~\"$environment\", service=~\"$service\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Probe Duration",
      "description": "Time taken for each HTTP probe to complete.",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"blackbox-http\", environment=~\"$environment\", service=~\"$service\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Status Code",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_http_status_code{job=\"blackbox-http\", environment=~\"$environment\", service=~\"$service\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "SSL Certificates",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Days Until SSL Expiry",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-http\", environment=~\"$environment\", service=~\"$service\"} - time()) / 86400",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "SSL Expiry Timeline",
      "gridPos": { "x": 8, "y": 14, "w": 16, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-http\", environment=~\"$environment\", service=~\"$service\"} - time()) / 86400",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      }
    }
  ]
}
